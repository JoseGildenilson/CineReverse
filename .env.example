# ==============================
# CineReserve API — Configuração
# ==============================
# Copie este arquivo para .env antes de rodar:
#   cp .env.example .env

# PostgreSQL (ajuste host: "cinereserve-db" para Docker, "localhost" para dev local)
DATABASE_URL=postgresql+asyncpg://cine_user:cine_pass@cinereserve-db:5432/cinereserve

# Redis (ajuste host: "cinereserve-redis" para Docker, "localhost" para dev local)
REDIS_URL=redis://cinereserve-redis:6379/0

# Chave secreta para assinar os tokens JWT
SECRET_KEY=troque-por-uma-chave-segura

# Modo debug (True para desenvolvimento, False para produção)
DEBUG=False

# Tempo de expiração do token JWT em minutos
ACCESS_TOKEN_EXPIRE_MINUTES=30
